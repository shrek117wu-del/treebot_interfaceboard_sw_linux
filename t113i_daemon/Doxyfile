# Doxyfile – Doxygen configuration for Seeway Interface Daemon (T113i)
#
# Generate documentation:
#   doxygen Doxyfile
#   # Output: docs/html/index.html

# ---------------------------------------------------------------------------
# Project
# ---------------------------------------------------------------------------
PROJECT_NAME           = "Seeway Interface Daemon"
PROJECT_BRIEF          = "T113i to Jetson communication daemon"
PROJECT_NUMBER         = "1.0.0"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
INPUT                  = src include
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.h *.hpp
EXCLUDE_PATTERNS       = */build/* */tests/*

# ---------------------------------------------------------------------------
# Output formats
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# ---------------------------------------------------------------------------
# HTML extras
# ---------------------------------------------------------------------------
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_SECTIONS  = YES
SEARCHENGINE           = YES

# ---------------------------------------------------------------------------
# Graphs (requires Graphviz dot)
# ---------------------------------------------------------------------------
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 50
DOT_TRANSPARENT        = YES

# ---------------------------------------------------------------------------
# Extraction settings
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SHOW_INCLUDE_FILES     = YES

# ---------------------------------------------------------------------------
# Source browser
# ---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---------------------------------------------------------------------------
# Documentation style
# ---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
TAB_SIZE               = 4

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"

# ---------------------------------------------------------------------------
# Preprocessing
# ---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = DOXYGEN_RUNNING

# ---------------------------------------------------------------------------
# Aliases for custom tags
# ---------------------------------------------------------------------------
ALIASES                = "thread_safe=@par Thread-Safety\n"
ALIASES               += "performance=@par Performance Notes\n"
