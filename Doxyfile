# Doxyfile – Doxygen configuration for T113i daemon API documentation
#
# Generate HTML + LaTeX output:
#   doxygen Doxyfile
#
# Output is written to docs/api/

PROJECT_NAME           = "T113i Interface Board Daemon"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Binary protocol daemon bridging T113i hardware to Jetson ROS 2"
OUTPUT_DIRECTORY       = docs/api

# Input
INPUT                  = t113i_daemon/include t113i_daemon/src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp
EXCLUDE_PATTERNS       = */build/*

# Output formats
GENERATE_HTML          = YES
GENERATE_LATEX         = YES
HTML_OUTPUT            = html
LATEX_OUTPUT           = latex

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
VERBATIM_HEADERS       = YES

# Graphs (requires graphviz / dot)
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# Extraction options
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

# Sort
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO
SORT_GROUP_NAMES       = NO

# Preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
PREDEFINED             =

# Search engine
SEARCHENGINE           = YES

# HTML theme
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = YES
